#!/bin/bash
#
# tes3mp-upload-mods — Upload mods to a remote TES3MP server
#
# This script reads the configuration from tes3mp-mods-upload.conf (next to this script),
# syncs the local mods directory to the server, and runs update_mods.sh.
#
# Configuration:
#   $(dirname "$0")/tes3mp-mods-upload.conf
#
# Usage:
#   tes3mp-upload-mods
#
# Dependencies: bash, rsync, ssh

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CONFIG_FILE="$SCRIPT_DIR/tes3mp-mods-upload.conf"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

err()  { echo -e "${RED}[ERROR]${NC} $*" >&2; }
ok()   { echo -e "${GREEN}[OK]${NC}   $*"; }

# --- Check config ---
if [ ! -f "$CONFIG_FILE" ]; then
    err "Config file not found: $CONFIG_FILE"
    echo ""
    echo "Edit the config template:"
    echo "  nano $CONFIG_FILE"
    exit 1
fi

# --- Source config ---
source "$CONFIG_FILE"

# --- Validate config ---
if [ -z "${SSH_HOST:-}" ]; then
    err "SSH_HOST is not set in $CONFIG_FILE"
    exit 1
fi

if [ -z "${MODS_DIR:-}" ]; then
    err "MODS_DIR is not set in $CONFIG_FILE"
    exit 1
fi

if [ ! -d "$MODS_DIR" ]; then
    err "Mods directory does not exist: $MODS_DIR"
    exit 1
fi

if [ -z "${SCRIPTS_DIR:-}" ]; then
    err "SCRIPTS_DIR is not set in $CONFIG_FILE"
    exit 1
fi

if [ ! -d "$SCRIPTS_DIR" ]; then
    err "Scripts directory does not exist: $SCRIPTS_DIR"
    exit 1
fi

# --- Check dependencies ---
for cmd in rsync ssh; do
    if ! command -v "$cmd" &>/dev/null; then
        err "'$cmd' not found. Install it and try again."
        exit 1
    fi
done

echo "=== TES3MP Mod & Script Upload ==="
echo "  SSH host:    $SSH_HOST"
echo "  Mods dir:    $MODS_DIR"
echo "  Scripts dir: $SCRIPTS_DIR"
echo ""

# --- Step 1: Sync mods ---
echo "[1/3] Syncing mods to server..."
rsync -avz --delete "$MODS_DIR"/ "$SSH_HOST":/opt/tes3mp/mods/
ok "Mods sync complete"

echo ""
# --- Step 2: Sync scripts ---
echo "[2/3] Syncing scripts to server..."
rsync -avz --delete "$SCRIPTS_DIR"/ "$SSH_HOST":/opt/tes3mp/scripts/
ok "Scripts sync complete"

echo ""
echo "[3/3] Running update_mods.sh on server..."
ssh "$SSH_HOST" "cd /opt/tes3mp && bash update_mods.sh"

echo ""
echo "=== Done! ==="